# HoYoverse International (OS) — IP-ASN + port combined rules
# Surge Rule Set
#
# Follows reference style: IP-ASN + DEST-PORT compound rules
# Each line is standalone — one game per line
#
# Usage:
#   RULE-SET,"/path/Hoyoverse_IP.list",HOYOVERSE
#

# Genshin Impact OS (port 22102 -> AWS)
OR,((AND,((IP-ASN,16509,no-resolve), (DEST-PORT,22102))),(AND,((IP-ASN,14618,no-resolve), (DEST-PORT,22102)))),HOYOVERSE

# Honkai: Star Rail OS (port 23301 -> AWS)
OR,((AND,((IP-ASN,16509,no-resolve), (DEST-PORT,23301))),(AND,((IP-ASN,14618,no-resolve), (DEST-PORT,23301)))),HOYOVERSE

# Zenless Zone Zero OS (port TBD)
# OR,((AND,((IP-ASN,16509,no-resolve), (DEST-PORT,XXXX))),(AND,((IP-ASN,14618,no-resolve), (DEST-PORT,XXXX)))),HOYOVERSE
